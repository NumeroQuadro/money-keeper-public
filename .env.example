# Required API configuration
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
API_ADMIN_TOKEN=generate-a-long-random-value
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Optional PostgreSQL settings
DB_SEARCH_PATH=public
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30

# Optional Telegram bot
BOT_TOKEN=
OWNER_TELEGRAM_ID=
API_BASE_URL=http://api:8000/api
BOT_LOG_LEVEL=INFO
MEDIA_GROUP_DEBOUNCE_SECONDS=1.0
RETRY_CACHE_TTL_SECONDS=3600
RETRY_CACHE_MAX_ITEMS=200
IMPORT_STATUS_POLL_SECONDS=2.0
IMPORT_STATUS_POLL_MAX_SECONDS=180.0
IMPORT_STATUS_POLL_MAX_ERRORS=3
API_RETRY_MAX_ATTEMPTS=3
API_RETRY_INITIAL_BACKOFF_SECONDS=0.5
API_RETRY_MAX_BACKOFF_SECONDS=4.0
